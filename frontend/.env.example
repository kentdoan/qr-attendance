# ============================================================================
# Biến môi trường (sao chép thành .env rồi điền giá trị thật)
# ============================================================================

# Bật/tắt mock API. true = dùng dữ liệu giả lập, không cần backend/Cognito.
VITE_USE_MOCK_API=true

# AWS Cognito (bắt buộc khi VITE_USE_MOCK_API=false)
VITE_AWS_REGION=ap-southeast-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_USER_POOL_CLIENT_ID=

# Base URL của API Gateway (bắt buộc khi VITE_USE_MOCK_API=false)
VITE_API_BASE_URL=https://your-api-id.execute-api.ap-southeast-1.amazonaws.com
